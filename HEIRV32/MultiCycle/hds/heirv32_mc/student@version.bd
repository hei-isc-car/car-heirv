text (MLText
uid 615,0
va (VaSet
)
xt "79200,18200,108700,42200"
st "
-- This block handles debug leds
dbg_sync: process(rst, clk)
begin
  if rst = '1' then
    dbg_leds <= (others => '0');
  elsif rising_edge(clk) then
	  dbg_leds <= (others => '0');
	-- Example of use:
    -- Shows address on first 8 leds
    --dbg_leds(7 downto 0) <=  std_ulogic_vector(adr(9 downto 2));
    -- Show instruction (7 downto 0) on next 8 leds
    --dbg_leds(15 downto 8) <= std_ulogic_vector(instruction(7 downto 0));
    -- 16 last leds are off
    --dbg_leds(31 downto 16) <= (others => '0');
  end if;
end process dbg_sync;





"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 24000
visibleWidth 30000
)
)
)
]
